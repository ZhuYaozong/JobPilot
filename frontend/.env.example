# JobPilot frontend environment
# Copy this file to frontend/.env. Vite only exposes variables prefixed with VITE_.

# Use "/" for local development with the Vite proxy in frontend/vite.config.ts.
# Use a full backend origin when deploying frontend and backend separately.
VITE_API_BASE_URL=/

# Axios request timeout for regular REST requests.
# Long assistant fallback requests override this in code.
VITE_API_TIMEOUT_MS=60000

# Keep true only when the backend also has AUTH_DEV_MODE=true.
# Set false in production so unauthenticated users are sent to /login.
VITE_AUTH_DEV_MODE=true

APP_NAME=JobPilot Backend
APP_ENV=local
APP_DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:123456@127.0.0.1:25432/jobpilot
REDIS_URL=redis://127.0.0.1:26379/0

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=

EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=
EMBEDDING_DIMENSIONS=1536

# Local development defaults. For production, set APP_ENV=production,
# APP_DEBUG=false, AUTH_DEV_MODE=false, and a strong unique AUTH_SECRET_KEY.
AUTH_SECRET_KEY=change-this-to-a-long-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_DEV_MODE=true

# JobPilot backend environment
# Copy this file to backend/.env. Never commit real backend/.env files.

# Application
APP_NAME=JobPilot Backend
APP_ENV=local
APP_DEBUG=true

# Data stores
# These defaults match the repository-root .env.example and compose.yaml.
DATABASE_URL=postgresql+asyncpg://postgres:123456@127.0.0.1:25432/jobpilot
REDIS_URL=redis://127.0.0.1:26379/0

# OpenAI-compatible chat completions endpoint
# Required for AI parsing, drafting, matching, artifact generation, and assistant workflows.
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL_NAME=replace-with-your-chat-model

# OpenAI-compatible embeddings endpoint
# Leave EMBEDDING_* blank to reuse the corresponding LLM_* settings.
# EMBEDDING_DIMENSIONS must match the database vector column dimension.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=
EMBEDDING_DIMENSIONS=1536

# Authentication
# Local development can keep AUTH_DEV_MODE=true to allow X-User-Name fallback.
# Production must use AUTH_DEV_MODE=false and a long random AUTH_SECRET_KEY.
AUTH_SECRET_KEY=change-this-to-a-long-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_DEV_MODE=true

# Production checklist:
# APP_ENV=production
# APP_DEBUG=false
# AUTH_DEV_MODE=false
# AUTH_SECRET_KEY=<long random secret>
# DATABASE_URL=<production database URL>
# REDIS_URL=<production Redis URL>
# LLM_API_KEY=<production key>

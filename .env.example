# JobPilot root environment
# Used by Docker Compose only. Copy this file to .env in the repository root.
# Never commit real .env files.

# PostgreSQL / pgvector local service
# The default password is for local development only.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=25432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=jobpilot

# Convenience URL for tools that need a plain psycopg-style PostgreSQL URL.
# If you change POSTGRES_* values above, update this URL as well.
DATABASE_URL=postgresql://postgres:123456@127.0.0.1:25432/jobpilot

# Redis local service
REDIS_HOST=127.0.0.1
REDIS_PORT=26379
REDIS_URL=redis://127.0.0.1:26379/0
